# Playbbit Frontend - Environment Configuration Example
# Copy this file to .env.local and update the values for your environment.

# --- API Configuration ---

# Public API URL (accessible by both client and server)
# This usually points to the Teeter Load Balancer or the main Backend API.
NEXT_PUBLIC_API_URL=http://your-teeter-ip:1996/api

# Optional: Alternative base URL if needed by specific components
# NEXT_PUBLIC_API_BASE_URL=http://your-api-base-url:port/api

# Internal API URL for server-side operations (e.g., Auth)
# This can bypass the load balancer and connect directly to the Playbbit-Backend.
AUTH_API_URL=http://your-backend-ip:1994/api


# --- Media Storage Configuration ---

# URL for MinIO or S3 compatible storage
NEXT_PUBLIC_MINIO_URL=http://your-minio-ip:9000/pbs

# Bucket name for media assets
NEXT_PUBLIC_MINIO_BUCKET=pbs


# --- NextAuth Configuration ---
# (Uncomment and set these if you are deploying to production)
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=your-next-auth-secret-key
