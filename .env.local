# API configuration
# Public API URL (accessible by both client and server)
NEXT_PUBLIC_API_URL=http://<device_ip>:1996/api

# Internal API URL for server-side auth (bypasses Teeter if needed)
AUTH_API_URL=http://<device_ip>:1994/api

# Media Storage (MinIO)
NEXT_PUBLIC_MINIO_URL=http://<device_ip>:9000/pbs
NEXT_PUBLIC_MINIO_BUCKET=pbs
